[gd_resource type="Resource" script_class="RogueEventData" format=3 uid="uid://d38xaamr7fekj"]

[ext_resource type="Script" uid="uid://b00ikvc3cacii" path="res://scripts/resources/rogue_event_data.gd" id="1"]
[ext_resource type="Texture2D" uid="uid://d1xe87wjdvsiy" path="res://assets/image/events/abyssal_baths.png" id="1_aq23u"]
[ext_resource type="Script" uid="uid://bbnxg8jy3qlgw" path="res://scripts/resources/rogue_event_option.gd" id="2"]
[ext_resource type="Script" uid="uid://moeco3vc1jqo" path="res://scripts/resources/rogue_effect_entry.gd" id="3"]

[sub_resource type="Resource" id="effect_1"]
script = ExtResource("3")
type = 12
param_int = 1
target_resource_path = "res://resources/enchants/pumpkin.tres"

[sub_resource type="Resource" id="effect_continue"]
script = ExtResource("3")
type = 14

[sub_resource type="Resource" id="option_1"]
script = ExtResource("2")
label = "南瓜灯附魔"
description = "选择一张卡牌，为其附魔南瓜灯保护"
effects = Array[ExtResource("3")]([SubResource("effect_1"), SubResource("effect_continue")])

[sub_resource type="Resource" id="effect_enchant_pick"]
script = ExtResource("3")
type = 12
param_int = 1
target_resource_path = "res://resources/enchants/inherent.tres"

[sub_resource type="Resource" id="Resource_17als"]
script = ExtResource("3")
type = 14

[sub_resource type="Resource" id="option_continue"]
script = ExtResource("2")
label = "继续"
description = "继续冒险"
effects = Array[ExtResource("3")]([SubResource("Resource_17als")])

[sub_resource type="Resource" id="effect_next_options"]
script = ExtResource("3")
type = 13
sub_options = Array[ExtResource("2")]([SubResource("option_continue")])
title_update = "哇哇肉！"
description_update = "你成功获得了固有附魔！"

[sub_resource type="Resource" id="option_2"]
script = ExtResource("2")
label = "固有附魔"
description = "选择一张卡牌，使其在每轮开始时立即出现"
effects = Array[ExtResource("3")]([SubResource("effect_enchant_pick"), SubResource("effect_next_options")])

[sub_resource type="Resource" id="effect_3"]
script = ExtResource("3")
type = 12
param_int = 1
target_resource_path = "res://resources/enchants/consumable.tres"

[sub_resource type="Resource" id="option_3"]
script = ExtResource("2")
label = "消耗附魔"
description = "选择一张卡牌，使用后不再回到卡组循环"
effects = Array[ExtResource("3")]([SubResource("effect_3"), SubResource("Resource_17als")])

[resource]
script = ExtResource("1")
id = &"enchant_selection"
title = "戴夫的附魔台"
description = "疯狂戴夫搬出了他的附魔台，可以为你的一张卡牌施加特殊附魔，你会选择哪一个？"
background_image = ExtResource("1_aq23u")
options = Array[ExtResource("2")]([SubResource("option_1"), SubResource("option_2"), SubResource("option_3")])
max_occurrences = -1
