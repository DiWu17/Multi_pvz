[resource]
script = ExtResource("4_nmth1")
id = &"enchant_selection"
title = "丛林迷宫奇遇"
description = "在一片花园的空地上，你撞见了一群寒碜的植物小队，他们正俯瞰着一座巨型迷宫并指手画脚。
他们邀请你入伙，共同开启一场搜刮迷宫财富的史诗级任务。身为老手，你心知肚明这迷宫里塞满了致命陷阱和僵尸。
搭伙干活确实容易些，但那样你就得跟人平分战利品了。"
background_image = ExtResource("1_idw67")
options = Array[ExtResource("2_7j6lx")]([SubResource("option_1"), SubResource("option_2")])
weight = 100
max_occurrences = -1
